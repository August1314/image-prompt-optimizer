# Optional provider fallbacks for local development or hosted deployment.
# The app now supports user-supplied provider keys from the UI, so these env vars
# are only needed when you want server-managed defaults.
# If neither a user key nor a matching env key is available, /api/optimize falls
# back to deterministic mock responses and the result page shows a mock-mode notice.
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=AIza-your-gemini-api-key-here

# Stripe checkout for the hosted buy page.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PRICE_ID=price_your_stripe_price_id_here
APP_BASE_URL=https://image-prompt-optimizer.vercel.app

# Production license signing.
# The hosted download endpoint signs .lic files with IPO_LICENSE_PRIVATE_KEY_PEM.
# The desktop runtime verifies them with the embedded production public key by default.
IPO_LICENSE_PRIVATE_KEY_PEM=

# Optional desktop license verification override.
# In local desktop development, the Electron app falls back to an embedded dev public key.
# Replace this in production builds if you move to a private signing workflow.
IPO_LICENSE_PUBLIC_KEY_PEM=

# Set automatically by Vercel in hosted environments.
# Keep localhost:3000 for local assumptions because vite.config.ts pins that port.
VERCEL_URL=localhost:3000
