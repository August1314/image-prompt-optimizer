# Optional for local Vite development.
# If omitted locally, the mock /api/optimize middleware is used.
# Required for real provider-backed verification and Vercel deployment.
OPENAI_API_KEY=sk-your-openai-api-key-here

# Set automatically by Vercel in hosted environments.
# Keep localhost:3000 for local assumptions because vite.config.ts pins that port.
VERCEL_URL=localhost:3000
