{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "electron"],
    "baseUrl": "."
  },
  "include": ["electron/**/*", "src/lib/**/*", "src/types/desktop-api.d.ts"],
  "exclude": ["src/**/*.test.*", "src/**/__tests__/**", "api/**/*.test.*"]
}
